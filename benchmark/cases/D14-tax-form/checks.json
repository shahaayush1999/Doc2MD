{
  "id": "D14-tax-form",
  "title": "Government Form Plus Instructions",
  "family": "forms_tables",
  "tags": [
    "form",
    "checkbox",
    "instructions",
    "line-numbers"
  ],
  "public": false,
  "checks": [
    {
      "id": "text-form-c-204",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Form C-204",
      "patterns": [
        "Form C-204"
      ]
    },
    {
      "id": "text-brookside-toolworks",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Brookside Toolworks",
      "patterns": [
        "Brookside Toolworks"
      ]
    },
    {
      "id": "text-employer-id-suffix-4821",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Employer ID suffix: 4821",
      "patterns": [
        "Employer ID suffix[\\s*_:\\-]{0,20}4821"
      ]
    },
    {
      "id": "forms-line-4-tentative-credit-10-368",
      "category": "forms",
      "weight": 1,
      "description": "Output should preserve: Line 4 Tentative credit: $10,368",
      "patterns": [
        "Line 4 Tentative credit[\\s*_:\\-]{0,20}\\$10,368"
      ]
    },
    {
      "id": "forms-carry-credit-forward",
      "category": "forms",
      "weight": 1,
      "description": "Output should preserve: Carry credit forward",
      "patterns": [
        "Carry credit forward"
      ]
    },
    {
      "id": "forms-domestic-equipment-content",
      "category": "forms",
      "weight": 1,
      "description": "Output should preserve: domestic equipment content",
      "patterns": [
        "domestic equipment content"
      ]
    },
    {
      "id": "special-do-not-round-line-4",
      "category": "special",
      "weight": 1,
      "description": "Output should preserve: Do not round Line 4",
      "patterns": [
        "Do not round Line 4"
      ]
    },
    {
      "id": "special-seven-years",
      "category": "special",
      "weight": 1,
      "description": "Output should preserve: seven years",
      "patterns": [
        "seven years"
      ]
    },
    {
      "id": "markdown-has-heading",
      "category": "markdown",
      "weight": 1,
      "description": "Output should contain at least one Markdown heading.",
      "patterns": [
        "^#\\s"
      ]
    },
    {
      "id": "no-json-wrapper",
      "category": "markdown",
      "weight": 1,
      "description": "Output should not be wrapped as JSON.",
      "mustNotPatterns": [
        "^\\s*\\{[\\s\\S]*\"markdown\""
      ]
    }
  ]
}
