{
  "id": "D11-multi-page-table",
  "title": "Multi-Page Table Continuation",
  "family": "tables",
  "tags": [
    "multi-page-table",
    "repeated-header",
    "footnote"
  ],
  "public": false,
  "checks": [
    {
      "id": "text-equipment-register",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Equipment Register",
      "patterns": [
        "Equipment Register"
      ]
    },
    {
      "id": "text-table-4-continues",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Table 4 continues",
      "patterns": [
        "Table 4 continues"
      ]
    },
    {
      "id": "text-total-active-assets-8",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Total active assets: 8",
      "patterns": [
        "Total active assets[\\s*_:\\-]{0,20}8"
      ]
    },
    {
      "id": "tables-eq-1001",
      "category": "tables",
      "weight": 1,
      "description": "Output should preserve: EQ-1001",
      "patterns": [
        "EQ-1001"
      ]
    },
    {
      "id": "tables-eq-1009",
      "category": "tables",
      "weight": 1,
      "description": "Output should preserve: EQ-1009",
      "patterns": [
        "EQ-1009"
      ]
    },
    {
      "id": "tables-blocked",
      "category": "tables",
      "weight": 1,
      "description": "Output should preserve: blocked",
      "patterns": [
        "blocked"
      ]
    },
    {
      "id": "tables-prairie",
      "category": "tables",
      "weight": 1,
      "description": "Output should preserve: Prairie",
      "patterns": [
        "Prairie"
      ]
    },
    {
      "id": "tables-eq-1012",
      "category": "tables",
      "weight": 1,
      "description": "Output should preserve: EQ-1012",
      "patterns": [
        "EQ-1012"
      ]
    },
    {
      "id": "special-footnote-1",
      "category": "special",
      "weight": 1,
      "description": "Output should preserve: Footnote 1",
      "patterns": [
        "Footnote 1"
      ]
    },
    {
      "id": "special-retired",
      "category": "special",
      "weight": 1,
      "description": "Output should preserve: retired",
      "patterns": [
        "retired"
      ]
    },
    {
      "id": "special-safety-review",
      "category": "special",
      "weight": 1,
      "description": "Output should preserve: safety review",
      "patterns": [
        "safety review"
      ]
    },
    {
      "id": "markdown-has-heading",
      "category": "markdown",
      "weight": 1,
      "description": "Output should contain at least one Markdown heading.",
      "patterns": [
        "^#\\s"
      ]
    },
    {
      "id": "no-json-wrapper",
      "category": "markdown",
      "weight": 1,
      "description": "Output should not be wrapped as JSON.",
      "mustNotPatterns": [
        "^\\s*\\{[\\s\\S]*\"markdown\""
      ]
    }
  ]
}
