{
  "id": "D18-infographic-timeline",
  "title": "Infographic Timeline",
  "family": "visual_layout",
  "tags": [
    "public",
    "infographic",
    "timeline",
    "icons"
  ],
  "public": true,
  "checks": [
    {
      "id": "text-incident-response-timeline",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Incident Response Timeline",
      "patterns": [
        "Incident Response Timeline"
      ]
    },
    {
      "id": "text-42-minutes",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: 42 minutes",
      "patterns": [
        "42 minutes"
      ]
    },
    {
      "id": "text-reliability-team",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Reliability team",
      "patterns": [
        "Reliability team"
      ]
    },
    {
      "id": "visual-09-10-alert-received",
      "category": "visual",
      "weight": 1,
      "description": "Output should preserve: 09:10 Alert received",
      "patterns": [
        "09[\\s*_:\\-]{0,20}10 Alert received"
      ]
    },
    {
      "id": "visual-09-27-mitigation-deployed",
      "category": "visual",
      "weight": 1,
      "description": "Output should preserve: 09:27 Mitigation deployed",
      "patterns": [
        "09[\\s*_:\\-]{0,20}27 Mitigation deployed"
      ]
    },
    {
      "id": "visual-09-52-error-rate-normal",
      "category": "visual",
      "weight": 1,
      "description": "Output should preserve: 09:52 Error rate normal",
      "patterns": [
        "09[\\s*_:\\-]{0,20}52 Error rate normal"
      ]
    },
    {
      "id": "visual-longest-gap-is-25-minutes",
      "category": "visual",
      "weight": 1,
      "description": "Output should preserve: longest gap is 25 minutes",
      "patterns": [
        "longest gap is 25 minutes"
      ]
    },
    {
      "id": "markdown-has-heading",
      "category": "markdown",
      "weight": 1,
      "description": "Output should contain at least one Markdown heading.",
      "patterns": [
        "^#\\s"
      ]
    },
    {
      "id": "no-json-wrapper",
      "category": "markdown",
      "weight": 1,
      "description": "Output should not be wrapped as JSON.",
      "mustNotPatterns": [
        "^\\s*\\{[\\s\\S]*\"markdown\""
      ]
    }
  ]
}
