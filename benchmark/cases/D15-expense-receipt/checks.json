{
  "id": "D15-expense-receipt",
  "title": "Receipt Scan",
  "family": "ocr_robustness",
  "tags": [
    "scan",
    "receipt",
    "mild-noise",
    "table"
  ],
  "public": false,
  "checks": [
    {
      "id": "text-harbor-market-receipt",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Harbor Market Receipt",
      "patterns": [
        "Harbor Market Receipt"
      ]
    },
    {
      "id": "text-hm-44918",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: HM-44918",
      "patterns": [
        "HM-44918"
      ]
    },
    {
      "id": "text-visa-ending-2041",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: VISA ending 2041",
      "patterns": [
        "VISA ending 2041"
      ]
    },
    {
      "id": "tables-field-notebook",
      "category": "tables",
      "weight": 1,
      "description": "Output should preserve: Field notebook",
      "patterns": [
        "Field notebook"
      ]
    },
    {
      "id": "tables-usb-c-cable",
      "category": "tables",
      "weight": 1,
      "description": "Output should preserve: USB-C cable",
      "patterns": [
        "USB-C cable"
      ]
    },
    {
      "id": "tables-black-coffee",
      "category": "tables",
      "weight": 1,
      "description": "Output should preserve: Black coffee",
      "patterns": [
        "Black coffee"
      ]
    },
    {
      "id": "forms-subtotal-30-72",
      "category": "forms",
      "weight": 1,
      "description": "Output should preserve: Subtotal: $30.72",
      "patterns": [
        "Subtotal[\\s*_:\\-]{0,20}\\$30\\.72"
      ]
    },
    {
      "id": "forms-tax-2-46",
      "category": "forms",
      "weight": 1,
      "description": "Output should preserve: Tax: $2.46",
      "patterns": [
        "Tax[\\s*_:\\-]{0,20}\\$2\\.46"
      ]
    },
    {
      "id": "forms-total-33-18",
      "category": "forms",
      "weight": 1,
      "description": "Output should preserve: Total: $33.18",
      "patterns": [
        "Total[\\s*_:\\-]{0,20}\\$33\\.18"
      ]
    },
    {
      "id": "markdown-has-heading",
      "category": "markdown",
      "weight": 1,
      "description": "Output should contain at least one Markdown heading.",
      "patterns": [
        "^#\\s"
      ]
    },
    {
      "id": "no-json-wrapper",
      "category": "markdown",
      "weight": 1,
      "description": "Output should not be wrapped as JSON.",
      "mustNotPatterns": [
        "^\\s*\\{[\\s\\S]*\"markdown\""
      ]
    }
  ]
}
