{
  "id": "D19-dashboard-page",
  "title": "Dashboard Business Report Page",
  "family": "visual_layout",
  "tags": [
    "dashboard",
    "chart",
    "kpi",
    "table"
  ],
  "public": false,
  "checks": [
    {
      "id": "text-weekly-revenue-dashboard",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Weekly Revenue Dashboard",
      "patterns": [
        "Weekly Revenue Dashboard"
      ]
    },
    {
      "id": "text-4-82m",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: $4.82M",
      "patterns": [
        "\\$4\\.82M"
      ]
    },
    {
      "id": "text-gross-retention-94-1",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Gross retention 94.1%",
      "patterns": [
        "Gross retention 94\\.1%"
      ]
    },
    {
      "id": "tables-atlas-bank",
      "category": "tables",
      "weight": 1,
      "description": "Output should preserve: Atlas Bank",
      "patterns": [
        "Atlas Bank"
      ]
    },
    {
      "id": "tables-nova-retail",
      "category": "tables",
      "weight": 1,
      "description": "Output should preserve: Nova Retail",
      "patterns": [
        "Nova Retail"
      ]
    },
    {
      "id": "tables-support-escalation",
      "category": "tables",
      "weight": 1,
      "description": "Output should preserve: support escalation",
      "patterns": [
        "support escalation"
      ]
    },
    {
      "id": "visual-revenue-by-segment",
      "category": "visual",
      "weight": 1,
      "description": "Output should preserve: Revenue by segment",
      "patterns": [
        "Revenue by segment"
      ]
    },
    {
      "id": "visual-enterprise-remains-the-larger-segment",
      "category": "visual",
      "weight": 1,
      "description": "Output should preserve: Enterprise remains the larger segment",
      "patterns": [
        "Enterprise remains the larger segment"
      ]
    },
    {
      "id": "visual-smb",
      "category": "visual",
      "weight": 1,
      "description": "Output should preserve: SMB",
      "patterns": [
        "SMB"
      ]
    },
    {
      "id": "markdown-has-heading",
      "category": "markdown",
      "weight": 1,
      "description": "Output should contain at least one Markdown heading.",
      "patterns": [
        "^#\\s"
      ]
    },
    {
      "id": "no-json-wrapper",
      "category": "markdown",
      "weight": 1,
      "description": "Output should not be wrapped as JSON.",
      "mustNotPatterns": [
        "^\\s*\\{[\\s\\S]*\"markdown\""
      ]
    }
  ]
}
