{
  "id": "D07-bank-statement",
  "title": "Bank Statement With Repeated Headers",
  "family": "tables",
  "tags": [
    "born-digital",
    "multi-page-table",
    "financial"
  ],
  "public": false,
  "checks": [
    {
      "id": "text-account-8842-1139",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Account: 8842-1139",
      "patterns": [
        "Account[\\s*_:\\-]{0,20}8842-1139"
      ]
    },
    {
      "id": "text-2026-06-01",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: 2026-06-01",
      "patterns": [
        "2026-06-01"
      ]
    },
    {
      "id": "text-closing-balance",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Closing balance",
      "patterns": [
        "Closing balance"
      ]
    },
    {
      "id": "tables-deposit-acme-payroll",
      "category": "tables",
      "weight": 1,
      "description": "Output should preserve: Deposit ACME PAYROLL",
      "patterns": [
        "Deposit ACME PAYROLL"
      ]
    },
    {
      "id": "tables-7-400-00",
      "category": "tables",
      "weight": 1,
      "description": "Output should preserve: $7,400.00",
      "patterns": [
        "\\$7,400\\.00"
      ]
    },
    {
      "id": "tables-wire-nexus-labs",
      "category": "tables",
      "weight": 1,
      "description": "Output should preserve: Wire NEXUS LABS",
      "patterns": [
        "Wire NEXUS LABS"
      ]
    },
    {
      "id": "tables-8-754-59",
      "category": "tables",
      "weight": 1,
      "description": "Output should preserve: $8,754.59",
      "patterns": [
        "\\$8,754\\.59"
      ]
    },
    {
      "id": "markdown-has-heading",
      "category": "markdown",
      "weight": 1,
      "description": "Output should contain at least one Markdown heading.",
      "patterns": [
        "^#\\s"
      ]
    },
    {
      "id": "no-json-wrapper",
      "category": "markdown",
      "weight": 1,
      "description": "Output should not be wrapped as JSON.",
      "mustNotPatterns": [
        "^\\s*\\{[\\s\\S]*\"markdown\""
      ]
    }
  ]
}
