      "id": "text-state-energy-resilience-review",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: State Energy Resilience Review",
      "patterns": [
        "State Energy Resilience Review"
      ]
    },
    {
      "id": "text-ser-2026-14",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: SER-2026-14",
      "patterns": [
        "SER-2026-14"
      ]
    },
    {
      "id": "text-rf-12",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: RF-12",
      "patterns": [
        "RF-12"
      ]
    },
    {
      "id": "text-ser-2026-14-b",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: SER-2026-14-B",
      "patterns": [
        "SER-2026-14-B"
      ]
