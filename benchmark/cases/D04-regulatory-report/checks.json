    },
    {
      "id": "structure-finding-b",
      "category": "structure",
      "weight": 1,
      "description": "Output should preserve: ### Finding B",
      "patterns": [
        "^#{1,6}\\s+Finding B"
      ]
    },
    {
      "id": "structure-appendix-4b",
      "category": "structure",
      "weight": 1,
      "description": "Output should preserve: Appendix 4B",
      "patterns": [
        "Appendix 4B"
      ]
