{
  "id": "D20-chart-heavy-page",
  "title": "Single Chart-Heavy Report Page",
  "family": "visual_layout",
  "tags": [
    "public",
    "chart",
    "caption",
    "numeric-tolerance"
  ],
  "public": true,
  "checks": [
    {
      "id": "text-figure-3-latency-by-pipeline-stage",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Figure 3. Latency by Pipeline Stage",
      "patterns": [
        "Figure 3\\. Latency by Pipeline Stage"
      ]
    },
    {
      "id": "text-10-000-production-conversions",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: 10,000 production conversions",
      "patterns": [
        "10,000 production conversions"
      ]
    },
    {
      "id": "text-440-ms",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: 440 ms",
      "patterns": [
        "440 ms"
      ]
    },
    {
      "id": "visual-reconstruct-is-the-slowest",
      "category": "visual",
      "weight": 1,
      "description": "Output should preserve: Reconstruct is the slowest",
      "patterns": [
        "Reconstruct is the slowest"
      ]
    },
    {
      "id": "visual-upload-is-the-fastest",
      "category": "visual",
      "weight": 1,
      "description": "Output should preserve: Upload is the fastest",
      "patterns": [
        "Upload is the fastest"
      ]
    },
    {
      "id": "visual-parse-480",
      "category": "visual",
      "weight": 1,
      "description": "Output should preserve: Parse=480",
      "patterns": [
        "Parse[\\s\\S]{0,80}480"
      ]
    },
    {
      "id": "visual-score-310",
      "category": "visual",
      "weight": 1,
      "description": "Output should preserve: Score=310",
      "patterns": [
        "Score[\\s\\S]{0,80}310"
      ]
    },
    {
      "id": "markdown-has-heading",
      "category": "markdown",
      "weight": 1,
      "description": "Output should contain at least one Markdown heading.",
      "patterns": [
        "^#\\s"
      ]
    },
    {
      "id": "no-json-wrapper",
      "category": "markdown",
      "weight": 1,
      "description": "Output should not be wrapped as JSON.",
      "mustNotPatterns": [
        "^\\s*\\{[\\s\\S]*\"markdown\""
      ]
    }
  ]
}
