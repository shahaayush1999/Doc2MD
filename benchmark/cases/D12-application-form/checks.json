{
  "id": "D12-application-form",
  "title": "Application Form",
  "family": "forms_tables",
  "tags": [
    "public",
    "form",
    "checkbox",
    "key-value"
  ],
  "public": true,
  "checks": [
    {
      "id": "text-vnd-2026-442",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: VND-2026-442",
      "patterns": [
        "VND-2026-442"
      ]
    },
    {
      "id": "text-cascade-metrics-llc",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Cascade Metrics LLC",
      "patterns": [
        "Cascade Metrics LLC"
      ]
    },
    {
      "id": "text-jordan-lee",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Jordan Lee",
      "patterns": [
        "Jordan Lee"
      ]
    },
    {
      "id": "forms-data-processing",
      "category": "forms",
      "weight": 1,
      "description": "Output should preserve: Data processing",
      "patterns": [
        "Data processing"
      ]
    },
    {
      "id": "forms-security-review-required",
      "category": "forms",
      "weight": 1,
      "description": "Output should preserve: Security review required",
      "patterns": [
        "Security review required"
      ]
    },
    {
      "id": "forms-soc-2-type-ii-complete",
      "category": "forms",
      "weight": 1,
      "description": "Output should preserve: SOC 2 Type II complete",
      "patterns": [
        "SOC 2 Type II complete"
      ]
    },
    {
      "id": "forms-duns-number",
      "category": "forms",
      "weight": 1,
      "description": "Output should preserve: DUNS number",
      "patterns": [
        "DUNS number"
      ]
    },
    {
      "id": "structure-banking-and-certification",
      "category": "structure",
      "weight": 1,
      "description": "Output should preserve: ## Banking and certification",
      "patterns": [
        "^#{1,6}\\s+Banking and certification"
      ]
    },
    {
      "id": "markdown-has-heading",
      "category": "markdown",
      "weight": 1,
      "description": "Output should contain at least one Markdown heading.",
      "patterns": [
        "^#\\s"
      ]
    },
    {
      "id": "no-json-wrapper",
      "category": "markdown",
      "weight": 1,
      "description": "Output should not be wrapped as JSON.",
      "mustNotPatterns": [
        "^\\s*\\{[\\s\\S]*\"markdown\""
      ]
    }
  ]
}
