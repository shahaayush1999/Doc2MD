{
  "id": "D06-invoice",
  "title": "Invoice With Line Items",
  "family": "forms_tables",
  "tags": [
    "public",
    "form",
    "simple-table",
    "key-value"
  ],
  "public": true,
  "checks": [
    {
      "id": "text-inv-2026-0719",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: INV-2026-0719",
      "patterns": [
        "INV-2026-0719"
      ]
    },
    {
      "id": "text-meridian-document-systems",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Meridian Document Systems",
      "patterns": [
        "Meridian Document Systems"
      ]
    },
    {
      "id": "text-helio-analytics-llc",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Helio Analytics LLC",
      "patterns": [
        "Helio Analytics LLC"
      ]
    },
    {
      "id": "text-net-30",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Net 30",
      "patterns": [
        "Net 30"
      ]
    },
    {
      "id": "tables-pdf-reconstruction-audit",
      "category": "tables",
      "weight": 1,
      "description": "Output should preserve: PDF reconstruction audit",
      "patterns": [
        "PDF reconstruction audit"
      ]
    },
    {
      "id": "tables-2-160-00",
      "category": "tables",
      "weight": 1,
      "description": "Output should preserve: $2,160.00",
      "patterns": [
        "\\$2,160\\.00"
      ]
    },
    {
      "id": "tables-visual-fact-rubric-review",
      "category": "tables",
      "weight": 1,
      "description": "Output should preserve: Visual fact rubric review",
      "patterns": [
        "Visual fact rubric review"
      ]
    },
    {
      "id": "forms-subtotal-3-785-00",
      "category": "forms",
      "weight": 1,
      "description": "Output should preserve: Subtotal: $3,785.00",
      "patterns": [
        "Subtotal[\\s*_:\\-]{0,20}\\$3,785\\.00"
      ]
    },
    {
      "id": "forms-tax-302-80",
      "category": "forms",
      "weight": 1,
      "description": "Output should preserve: Tax: $302.80",
      "patterns": [
        "Tax[\\s*_:\\-]{0,20}\\$302\\.80"
      ]
    },
    {
      "id": "forms-total-due-4-087-80",
      "category": "forms",
      "weight": 1,
      "description": "Output should preserve: Total due: $4,087.80",
      "patterns": [
        "Total due[\\s*_:\\-]{0,20}\\$4,087\\.80"
      ]
    },
    {
      "id": "markdown-has-heading",
      "category": "markdown",
      "weight": 1,
      "description": "Output should contain at least one Markdown heading.",
      "patterns": [
        "^#\\s"
      ]
    },
    {
      "id": "no-json-wrapper",
      "category": "markdown",
      "weight": 1,
      "description": "Output should not be wrapped as JSON.",
      "mustNotPatterns": [
        "^\\s*\\{[\\s\\S]*\"markdown\""
      ]
    }
  ]
}
