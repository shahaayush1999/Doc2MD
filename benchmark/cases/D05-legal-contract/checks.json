{
  "id": "D05-legal-contract",
  "title": "Legal Contract Excerpt",
  "family": "text_structure",
  "tags": [
    "born-digital",
    "nested-list",
    "signature-block"
  ],
  "public": false,
  "checks": [
    {
      "id": "text-master-services-agreement",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Master Services Agreement",
      "patterns": [
        "Master Services Agreement"
      ]
    },
    {
      "id": "text-msa-arc-2026-09",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: MSA-ARC-2026-09",
      "patterns": [
        "MSA-ARC-2026-09"
      ]
    },
    {
      "id": "text-northstar-data-llc",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: Northstar Data LLC",
      "patterns": [
        "Northstar Data LLC"
      ]
    },
    {
      "id": "text-usd-250-000",
      "category": "text",
      "weight": 1,
      "description": "Output should preserve: USD 250,000",
      "patterns": [
        "USD 250,000"
      ]
    },
    {
      "id": "structure-1-definitions",
      "category": "structure",
      "weight": 1,
      "description": "Output should preserve: ## 1. Definitions",
      "patterns": [
        "^#{1,6}\\s+1\\. Definitions"
      ]
    },
    {
      "id": "structure-1-1",
      "category": "structure",
      "weight": 1,
      "description": "Output should preserve: 1.1",
      "patterns": [
        "1\\.1"
      ]
    },
    {
      "id": "structure-3-acceptance",
      "category": "structure",
      "weight": 1,
      "description": "Output should preserve: ## 3. Acceptance",
      "patterns": [
        "^#{1,6}\\s+3\\. Acceptance"
      ]
    },
    {
      "id": "structure-signature-block",
      "category": "structure",
      "weight": 1,
      "description": "Output should preserve: ## Signature Block",
      "patterns": [
        "^#{1,6}\\s+Signature Block"
      ]
    },
    {
      "id": "special-confidential-information",
      "category": "special",
      "weight": 1,
      "description": "Output should preserve: Confidential Information",
      "patterns": [
        "Confidential Information"
      ]
    },
    {
      "id": "special-deliverables",
      "category": "special",
      "weight": 1,
      "description": "Output should preserve: Deliverables",
      "patterns": [
        "Deliverables"
      ]
    },
    {
      "id": "special-five-business-days",
      "category": "special",
      "weight": 1,
      "description": "Output should preserve: five business days",
      "patterns": [
        "five business days"
      ]
    },
    {
      "id": "markdown-has-heading",
      "category": "markdown",
      "weight": 1,
      "description": "Output should contain at least one Markdown heading.",
      "patterns": [
        "^#\\s"
      ]
    },
    {
      "id": "no-json-wrapper",
      "category": "markdown",
      "weight": 1,
      "description": "Output should not be wrapped as JSON.",
      "mustNotPatterns": [
        "^\\s*\\{[\\s\\S]*\"markdown\""
      ]
    }
  ]
}
