      "weight": 5,
      "pattern": "(current|replacement|non-struck)[\\s\\S]{0,180}\\$14,200[\\s\\S]{0,120}45 days[\\s\\S]{0,120}Premium[\\s\\S]{0,120}15 business days[\\s\\S]{0,120}North-7|\\$14,200[\\s\\S]{0,120}45 days[\\s\\S]{0,120}Premium[\\s\\S]{0,120}15 business days[\\s\\S]{0,120}North-7[\\s\\S]{0,180}(current|replacement|non-struck)"
